{
  "name": "@unsone/db",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./core": "./src/db.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "lint": "eslint",
    "db:push": "pnpm with-env drizzle-kit push",
    "db:studio": "pnpm with-env drizzle-kit studio",
    "db:migrate": "pnpm with-env drizzle-kit migrate",
    "db:generate": "pnpm with-env drizzle-kit generate",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@t3-oss/env-core": "catalog:",
    "@types/node": "catalog:",
    "@unsone/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "typescript": "catalog:"
  }
}
