    "@unsone/trpc": "workspace:*",
    "better-auth": "catalog:",
    "next": "16.2.9",
    "server-only": "^0.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@unsone/eslint-config": "workspace:*",
    "@unsone/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "eslint-config-expo": "catalog:",
    "jiti": "^2.7.0",
    "typescript": "catalog:"
  }
